<Window x:Class="NurseScheduler.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NurseScheduler.UI.Views.Nurses"
        xmlns:viewModels="clr-namespace:NurseScheduler.UI.ViewModels"
        Title="{Binding Title}" Height="450" Width="800">

    <Window.DataContext>
        <viewModels:MainWindowViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="{Binding Title}" FontSize="20" Margin="0,0,0,10" />
            <views:NurseListView />
        </StackPanel>
    </Grid>
</Window>