<Window x:Class="NurseScheduler.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding WindowTitle}" Height="750" Width="1280" MinHeight="600" MinWidth="1000"
        Background="{StaticResource AppBackground}" WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontFamily="{DynamicResource MaterialDesignFont}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource NavBackground}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,20,16,12" Background="#0D0D1A">
                    <StackPanel>
                        <TextBlock Text="🏥" FontSize="28" HorizontalAlignment="Center"/>
                        <TextBlock Text="NurseScheduler" FontSize="15" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBlock Text="Pro" FontSize="11" Foreground="#00BCD4" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                        <Separator Margin="0,12,0,0" Background="#2D2D4E"/>
                        <TextBlock Text="{Binding HospitalName}" FontSize="11" Foreground="#78909C" HorizontalAlignment="Center" Margin="0,6,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="GENEL" Foreground="#546E7A" FontSize="10" Margin="20,12,0,4" FontWeight="Bold"/>

                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Dashboard">
                            <StackPanel Orientation="Horizontal" >
                                <materialDesign:PackIcon Kind="ViewDashboard" VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="VERİ YÖNETİMİ" Foreground="#546E7A" FontSize="10" Margin="20,12,0,4" FontWeight="Bold"/>

                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Nurses">
                            <StackPanel Orientation="Horizontal" >
                                <materialDesign:PackIcon Kind="AccountGroup" VerticalAlignment="Center"/>
                                <TextBlock Text="Hemşire Yönetimi" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Units">
                            <StackPanel Orientation="Horizontal" >
                                <materialDesign:PackIcon Kind="Hospital" VerticalAlignment="Center"/>
                                <TextBlock Text="Birim Yönetimi" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Shifts">
                            <StackPanel Orientation="Horizontal" >
                                <materialDesign:PackIcon Kind="ClockOutline" VerticalAlignment="Center"/>
                                <TextBlock Text="Vardiya Tanımları" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Rules">
                            <StackPanel Orientation="Horizontal" >
                                <materialDesign:PackIcon Kind="ShieldCheck" VerticalAlignment="Center"/>
                                <TextBlock Text="Kural Yönetimi" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="ÇİZELGELEME" Foreground="#546E7A" FontSize="10" Margin="20,12,0,4" FontWeight="Bold"/>

                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="CreateSchedule">
                            <StackPanel Orientation="Horizontal" >
                                <materialDesign:PackIcon Kind="CalendarPlus" VerticalAlignment="Center"/>
                                <TextBlock Text="Çizelge Oluştur" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="ViewSchedule">
                            <StackPanel Orientation="Horizontal" >
                                <materialDesign:PackIcon Kind="CalendarMonth" VerticalAlignment="Center"/>
                                <TextBlock Text="Çizelge Görüntüle" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Reports">
                            <StackPanel Orientation="Horizontal" >
                                <materialDesign:PackIcon Kind="FileExcel" VerticalAlignment="Center"/>
                                <TextBlock Text="Raporlar &amp; Excel" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="SİSTEM" Foreground="#546E7A" FontSize="10" Margin="20,12,0,4" FontWeight="Bold"/>

                        <Button Style="{StaticResource NavButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="Settings">
                            <StackPanel Orientation="Horizontal" >
                                <materialDesign:PackIcon Kind="Cog" VerticalAlignment="Center"/>
                                <TextBlock Text="Ayarlar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <Border DockPanel.Dock="Bottom" Padding="16,8" Background="#0D0D1A">
                    <TextBlock Text="v1.0.0 — NurseScheduler Pro" FontSize="10" Foreground="#37474F" HorizontalAlignment="Center"/>
                </Border>
            </DockPanel>
        </Border>

        <Frame Grid.Column="1" x:Name="ContentFrame" NavigationUIVisibility="Hidden" Background="{StaticResource AppBackground}"/>
    </Grid>
</Window>
