<Page x:Class="NurseScheduler.UI.Views.Shifts.ShiftsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{StaticResource AppBackground}" Title="Vardiya Tanımları">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="🕒  Vardiya Tanımları" Style="{StaticResource PageTitleStyle}"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="#1A1A2E" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="YENİ / DÜZENLE" FontSize="11" FontWeight="Bold" Foreground="#546E7A" Margin="0,0,0,12"/>
                    <TextBox Foreground="White" CaretBrush="White" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Vardiya Adı (Örn: Gündüz) *" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBox Foreground="White" CaretBrush="White" Grid.Column="0" Text="{Binding StartTime}" materialDesign:HintAssist.Hint="Başlangıç (08:00)" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        <TextBox Foreground="White" CaretBrush="White" Grid.Column="2" Text="{Binding EndTime}" materialDesign:HintAssist.Hint="Bitiş (16:00)" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    </Grid>
                    <ComboBox Foreground="White" SelectedValue="{Binding ColorHex}" SelectedValuePath="Tag" materialDesign:HintAssist.Hint="Vardiya Rengi (Örn: Mavi)" Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,10">
                        <ComboBoxItem Tag="#E53935">
                            <StackPanel Orientation="Horizontal"><Border Width="16" Height="16" Background="#E53935" CornerRadius="4" Margin="0,0,8,0"/><TextBlock Text="Kırmızı"/></StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="#1E88E5">
                            <StackPanel Orientation="Horizontal"><Border Width="16" Height="16" Background="#1E88E5" CornerRadius="4" Margin="0,0,8,0"/><TextBlock Text="Mavi"/></StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="#00897B">
                            <StackPanel Orientation="Horizontal"><Border Width="16" Height="16" Background="#00897B" CornerRadius="4" Margin="0,0,8,0"/><TextBlock Text="Koyu Yeşil"/></StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="#43A047">
                            <StackPanel Orientation="Horizontal"><Border Width="16" Height="16" Background="#43A047" CornerRadius="4" Margin="0,0,8,0"/><TextBlock Text="Yeşil"/></StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="#FB8C00">
                            <StackPanel Orientation="Horizontal"><Border Width="16" Height="16" Background="#FB8C00" CornerRadius="4" Margin="0,0,8,0"/><TextBlock Text="Turuncu"/></StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="#8E24AA">
                            <StackPanel Orientation="Horizontal"><Border Width="16" Height="16" Background="#8E24AA" CornerRadius="4" Margin="0,0,8,0"/><TextBlock Text="Mor"/></StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="#FDD835">
                            <StackPanel Orientation="Horizontal"><Border Width="16" Height="16" Background="#FDD835" CornerRadius="4" Margin="0,0,8,0"/><TextBlock Text="Sarı"/></StackPanel>
                        </ComboBoxItem>
                        <ComboBoxItem Tag="#1A1A2E">
                            <StackPanel Orientation="Horizontal"><Border Width="16" Height="16" Background="#1A1A2E" CornerRadius="4" Margin="0,0,8,0"/><TextBlock Text="Siyah (İzin)"/></StackPanel>
                        </ComboBoxItem>
                    </ComboBox>
                    <CheckBox Content="Gece Vardiyası" IsChecked="{Binding IsNight}" Foreground="White" Margin="0,0,0,6"/>
                    <CheckBox Content="Aktif" IsChecked="{Binding IsActive}" Foreground="White" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Yeni" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding NewCommand}" Margin="0,0,8,0"/>
                        <Button Content="Kaydet" Style="{StaticResource MaterialDesignRaisedButton}" Background="#00C853" Command="{Binding SaveCommand}" Margin="0,0,8,0"/>
                        <Button Content="İptal" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding CancelCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
            <Border Grid.Column="2" Background="#1A1A2E" CornerRadius="12" Padding="16">
                <DataGrid ItemsSource="{Binding Shifts}" SelectedItem="{Binding Selected}" AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="None" Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#1E1E35" HeadersVisibility="Column" ColumnHeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}" RowStyle="{StaticResource MaterialDesignDataGridRow}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Renk" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="16" Height="16" CornerRadius="4" Background="{Binding ColorHex}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Adı" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Başlangıç" Binding="{Binding StartTime}" Width="80"/>
                        <DataGridTextColumn Header="Bitiş" Binding="{Binding EndTime}" Width="80"/>
                        <DataGridTextColumn Header="Saat" Binding="{Binding DurationHours}" Width="60"/>
                        <DataGridCheckBoxColumn Header="Gece" Binding="{Binding IsNightShift}" Width="60"/>
                        <DataGridTemplateColumn Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" Style="{StaticResource MaterialDesignIconButton}" Foreground="#EF5350" Width="24" Height="24">
                                        <materialDesign:PackIcon Kind="Delete"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</Page>
