<Page x:Class="NurseScheduler.UI.Views.Rules.RulesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{StaticResource AppBackground}" Title="Kural Yönetimi">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="🛡  Kural Yönetimi" Style="{StaticResource PageTitleStyle}"/>
        <Border Grid.Row="1" Background="#1A1A2E" CornerRadius="12" Padding="20" Margin="0,0,0,16">
            <TextBlock TextWrapping="Wrap" Foreground="#B0BEC5" FontSize="13" LineHeight="20">
                <Run Text="Sistemdeki kurallar" FontWeight="Bold"/> <Run Text="akademik modeller (Arslan &amp; Özcan 2022, Bayraktar 2022)" Foreground="#00BCD4"/> 
                <Run Text="referans alınarak oluşturulmuştur. Özel önceliklerinizi düzenlemek için sağdaki kalem ikonuna tıklayarak Ceza Puanını 1-10 arasında ayarlayabilirsiniz."/>
            </TextBlock>
        </Border>
        
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0" Background="#1A1A2E" CornerRadius="12" Padding="16">
                <!-- Select using pencil icon only -->
                <DataGrid ItemsSource="{Binding Rules}" AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="None" Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#1E1E35" HeadersVisibility="Column" ColumnHeaderStyle="{StaticResource MaterialDesignDataGridColumnHeader}" RowStyle="{StaticResource MaterialDesignDataGridRow}" IsReadOnly="True" SelectionMode="Single" RowHeight="40">
                    <DataGrid.Columns>
                        <!-- Pencil Icon -->
                        <DataGridTemplateColumn Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}" Background="Transparent" BorderThickness="0" Foreground="#00E676" Width="28" Height="28" Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Aktif" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" Command="{Binding DataContext.ToggleActiveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Kategori" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Padding="8,4" CornerRadius="4" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Category}" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Kural" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Ceza Puanı" Binding="{Binding PenaltyScore}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Edit Form -->
            <Border Grid.Column="2" Background="#1A1A2E" CornerRadius="12" Padding="20" Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="KURAL ÖNCELİĞİ AYARLA" FontSize="11" FontWeight="Bold" Foreground="#546E7A" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding RuleName}" Foreground="White" FontSize="16" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding RuleDesc}" Foreground="#B0BEC5" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,24"/>
                    
                    <TextBlock Text="Kategori" Foreground="#78909C" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox Foreground="White" SelectedValue="{Binding Category}" SelectedValuePath="Content" Style="{StaticResource MaterialDesignOutlinedComboBox}" Margin="0,0,0,16" IsEnabled="{Binding CanDelete}">
                        <ComboBoxItem Content="SOFT"/>
                        <ComboBoxItem Content="HARD"/>
                    </ComboBox>

                    <TextBlock Text="Ceza Puanı Önem Derecesi (1-10)" Foreground="#78909C" FontSize="12" Margin="0,0,0,8"/>
                    <Slider Minimum="1" Maximum="10" Value="{Binding Penalty}" TickFrequency="1" IsSnapToTickEnabled="True" Foreground="#3D5AFE" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding Penalty, StringFormat='{}Seçili Puan: {0}'}" FontSize="16" FontWeight="Bold" Foreground="#00C853" HorizontalAlignment="Center" Margin="0,0,0,24"/>

                    <CheckBox Content="Aktif Kural" IsChecked="{Binding Active}" Foreground="White" Margin="0,0,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="İptal" Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding CancelCommand}" Margin="0,0,12,0"/>
                        <Button Content="Kaydet" Style="{StaticResource MaterialDesignRaisedButton}" Background="#00C853" Command="{Binding SaveCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
