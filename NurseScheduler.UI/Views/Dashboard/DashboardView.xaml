<Page x:Class="NurseScheduler.UI.Views.Dashboard.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="{StaticResource AppBackground}" Title="Dashboard">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="📊  Dashboard" Style="{StaticResource PageTitleStyle}"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#1A1A2E" CornerRadius="14" Margin="0,0,12,0" Padding="22,18">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="AccountGroup" Width="30" Height="30" Foreground="#3D5AFE"/>
                        <TextBlock Text="{Binding NurseCount}" Style="{StaticResource StatValueStyle}" Margin="0,8,0,0"/>
                        <TextBlock Text="Toplam Hemşire" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#1A1A2E" CornerRadius="14" Margin="0,0,12,0" Padding="22,18">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Hospital" Width="30" Height="30" Foreground="#00BCD4"/>
                        <TextBlock Text="{Binding UnitCount}" Style="{StaticResource StatValueStyle}" Foreground="#00BCD4" Margin="0,8,0,0"/>
                        <TextBlock Text="Birim / Alt Birim" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#1A1A2E" CornerRadius="14" Margin="0,0,12,0" Padding="22,18">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="ClockOutline" Width="30" Height="30" Foreground="#FFB300"/>
                        <TextBlock Text="{Binding ShiftCount}" Style="{StaticResource StatValueStyle}" Foreground="#FFB300" Margin="0,8,0,0"/>
                        <TextBlock Text="Vardiya Tipi" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="#1A1A2E" CornerRadius="14" Padding="22,18">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="ShieldCheck" Width="30" Height="30" Foreground="#00C853"/>
                        <TextBlock Text="{Binding ActiveRuleCount}" Style="{StaticResource StatValueStyle}" Foreground="#00C853" Margin="0,8,0,0"/>
                        <TextBlock Text="Aktif Kural" Style="{StaticResource StatLabelStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="#1A1A2E" CornerRadius="14" Padding="22" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="SON ÇİZELGE" FontSize="11" FontWeight="Bold" Foreground="#546E7A" Margin="0,0,0,14"/>
                    <Grid Visibility="{Binding HasLastSchedule, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding LastScheduleName}" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="{Binding LastScheduleDateRange}" FontSize="13" Foreground="#78909C" Margin="0,4,0,0"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding LastScheduleFitness}" FontSize="30" FontWeight="Bold" Foreground="#00BCD4"/>
                    </Grid>
                    <TextBlock Text="Henüz Çizelge oluşturulmamış. 'Çizelge Oluştur' menüsünden başlayın."
                               Visibility="{Binding NoSchedule, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Foreground="#546E7A" FontSize="13"/>
                </StackPanel>
            </Border>

            <TextBlock Text="HIZLI ERİŞİM" FontSize="11" FontWeight="Bold" Foreground="#546E7A" Margin="0,0,0,12"/>
            <WrapPanel>
                <Button Style="{StaticResource MaterialDesignRaisedButton}" Background="#3D5AFE" Command="{Binding QuickScheduleCommand}" Margin="0,0,12,8" Padding="18,12" Height="44">
                    <StackPanel Orientation="Horizontal" >
                        <materialDesign:PackIcon Kind="CalendarPlus" VerticalAlignment="Center"/>
                        <TextBlock Text="Yeni Çizelge Oluştur" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignRaisedButton}" Background="#00838F" Command="{Binding QuickNurseCommand}" Margin="0,0,12,8" Padding="18,12" Height="44">
                    <StackPanel Orientation="Horizontal" >
                        <materialDesign:PackIcon Kind="AccountPlus" VerticalAlignment="Center"/>
                        <TextBlock Text="Hemşire Ekle" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource MaterialDesignRaisedButton}" Background="#2E7D32" Command="{Binding QuickExcelCommand}" Margin="0,0,12,8" Padding="18,12" Height="44">
                    <StackPanel Orientation="Horizontal" >
                        <materialDesign:PackIcon Kind="FileExcel" VerticalAlignment="Center"/>
                        <TextBlock Text="Excel İndir" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
