<Window x:Class="NurseScheduler.UI.Views.Schedule.AlgorithmProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Algoritma Çalışıyor..." Height="600" Width="800"
        WindowStartupLocation="CenterOwner" ResizeMode="CanMinimize"
        Background="{StaticResource AppBackground}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding StatusMessage}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,16" HorizontalAlignment="Center"/>
        
        <!-- Progress Bar -->
        <ProgressBar Grid.Row="1" Value="{Binding Progress}" Maximum="100" Height="8" Foreground="#00BCD4" Background="#1E1E35" BorderThickness="0" Margin="0,0,0,24"/>

        <!-- Realtime Stats -->
        <Grid Grid.Row="2" Margin="0,0,0,24">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="NESİL" FontSize="11" Foreground="#546E7A" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Generation}" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="EN İYİ UYGUNLUK" FontSize="11" Foreground="#546E7A" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding BestFitness, StringFormat=\{0:N1\}}" FontSize="24" FontWeight="Bold" Foreground="#00C853" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="KURAL İHLALİ" FontSize="11" Foreground="#546E7A" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding Violations}" FontSize="24" FontWeight="Bold" Foreground="#FFB300" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="3">
                <TextBlock Text="SÜRE" FontSize="11" Foreground="#546E7A" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding ElapsedTime}" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Live Console Logs -->
        <Border Grid.Row="3" Background="#0A0A10" CornerRadius="8" Padding="16">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Logs}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock Text="{Binding Time}" Foreground="#546E7A" FontFamily="Consolas" Width="60"/>
                                <TextBlock Text="{Binding Message}" Foreground="{Binding Color}" FontFamily="Consolas" TextWrapping="Wrap" MaxWidth="600"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Actions -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="İPTAL ET" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="#EF5350" Command="{Binding CancelCommand}" Margin="0,0,16,0" Visibility="{Binding IsDone, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
            <Button Content="ÇİZELGEYİ GÖRÜNTÜLE" Style="{StaticResource MaterialDesignRaisedButton}" Background="#3D5AFE" Command="{Binding ViewScheduleCommand}" Visibility="{Binding IsDone, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</Window>
