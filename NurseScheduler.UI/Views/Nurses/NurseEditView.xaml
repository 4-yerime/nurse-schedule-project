<UserControl x:Class="NurseScheduler.UI.Views.Nurses.NurseEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:NurseScheduler.UI.Views.Nurses"
             mc:Ignorable="d" d:DesignHeight="350" d:DesignWidth="400">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Vertical" Grid.Row="0" Margin="0,0,0,10">

            <TextBlock Text="Hemşire Bilgileri" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Ad:" Width="80" VerticalAlignment="Center"/>
                <TextBox Text="{Binding CurrentNurse.FirstName, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Soyad:" Width="80" VerticalAlignment="Center"/>
                <TextBox Text="{Binding CurrentNurse.LastName, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Baş Hemşire:" Width="80" VerticalAlignment="Center"/>
                <CheckBox IsChecked="{Binding CurrentNurse.IsHeadNurse}" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Çalışma Tipi:" Width="80" VerticalAlignment="Center"/>
                <ComboBox Width="200" SelectedValue="{Binding CurrentNurse.EmploymentType}" >
                    <ComboBoxItem Content="FULL" />
                    <ComboBoxItem Content="PART" />
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Max Aylık Saat:" Width="80" VerticalAlignment="Center"/>
                <TextBox Text="{Binding CurrentNurse.MaxMonthlyHours, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Yıllık İzin:" Width="80" VerticalAlignment="Center"/>
                <TextBox Text="{Binding CurrentNurse.AnnualLeaveBalance, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
            </StackPanel>

        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="1" Margin="0,0,0,0">
            <Button Content="Kaydet" Command="{Binding SaveCommand}" Width="80" Margin="0,0,10,0"/>
            <Button Content="İptal" Command="{Binding CancelCommand}" Width="80"/>
        </StackPanel>
    </Grid>

</UserControl>